<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1280.0" stylesheets="@stile.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unipv.ingsfw.controller.AdminLoginController">
    <children>
        <Label alignment="TOP_CENTER" layoutY="50.0" text="GOLF TEE TIME MANAGER" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="50.0" style="-fx-text-fill: linear-gradient(to right, #ffffff 30%, #00f2fe 100%); -fx-font-weight: 900; -fx-letter-spacing: 4px;">
            <font>
                <Font name="System Bold" size="46.0" />
            </font>
        </Label>

        <VBox alignment="CENTER" fillWidth="false" maxWidth="400.0" spacing="15.0" AnchorPane.bottomAnchor="100.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button alignment="CENTER" blendMode="COLOR_DODGE" mnemonicParsing="false" mouseTransparent="true" prefHeight="45.0" prefWidth="400.0" style="-fx-background-color: rgba(255,255,255,0.08); -fx-text-fill: #00f2fe; -fx-background-radius: 5; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 5;" text="ACCESSO AMMINISTRATORE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Button>

                <PasswordField fx:id="pfPassword" alignment="CENTER" prefHeight="45.0" prefWidth="400.0" promptText="INSERISCI PASSWORD" style="-fx-text-fill: #ffffff; -fx-control-inner-background: rgba(255,255,255,0.11); -fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 5; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </PasswordField>

                <Label fx:id="lblError" alignment="CENTER" prefHeight="25.0" prefWidth="400.0" textFill="#ff1206" style="-fx-font-weight: bold;">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER" spacing="20.0" prefWidth="400.0">
                    <children>
                        <Button alignment="CENTER" blendMode="COLOR_DODGE" mnemonicParsing="false" onAction="#onIndietro" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;" text="INDIETRO">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Button>
                        <Button alignment="CENTER" blendMode="COLOR_DODGE" mnemonicParsing="false" onAction="#onAccedi" prefHeight="45.0" prefWidth="190.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 5;" text="ACCEDI">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>